{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "classpath:/schema/engine-template-v1.json",
  "title": "Engine Execution Template v1",
  "type": "object",
  "required": ["bizCode", "name", "version", "params", "executors", "tasks"],
  "additionalProperties": false,

  "properties": {
    "bizCode": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "projectGroupId": {
      "type": ["string", "null"]
    },
    "projectId": {
      "type": ["string", "null"]
    },
    "version": {
      "type": "string",
      "minLength": 1
    },

    "params": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/kvParam"
      }
    },

    "cmds": {
      "type": ["array", "null"],
      "items": {
        "type": "object"
      }
    },

    "executors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/executor"
      }
    },

    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/task"
      }
    }
  },

  "definitions": {
    "kvParam": {
      "type": "object",
      "required": ["k", "v"],
      "additionalProperties": false,
      "properties": {
        "k": {
          "type": "string",
          "minLength": 1
        },
        "v": {
          "type": [
            "string",
            "number",
            "boolean",
            "array",
            "object",
            "null"
          ]
        }
      }
    },

    "executor": {
      "type": "object",
      "required": ["step", "cmdName"],
      "additionalProperties": false,
      "properties": {
        "step": {
          "type": "string",
          "minLength": 1
        },
        "cmdName": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": ["array", "null"],
          "items": {
            "$ref": "#/definitions/kvParam"
          }
        }
      }
    },

    "task": {
      "type": "object",
      "required": ["taskId", "input", "output"],
      "additionalProperties": false,
      "properties": {
        "taskId": {
          "type": "string",
          "minLength": 1
        },

        "input": {
          "$ref": "#/definitions/taskInput"
        },

        "output": {
          "$ref": "#/definitions/taskOutput"
        }
      }
    },

    "taskInput": {
      "type": "object",
      "required": ["types", "params"],
      "additionalProperties": false,
      "properties": {
        "types": {
          "type": "array"
        },
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/kvParam"
          }
        }
      }
    },

    "taskOutput": {
      "type": "object",
      "required": ["types"],
      "additionalProperties": false,
      "properties": {
        "types": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/outputType"
          }
        }
      }
    },

    "outputType": {
      "type": "object",
      "required": ["path", "storeType", "required"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fileName": {
          "type": "string"
        },
        "storeType": {
          "type": "string"
        },
        "tar": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        }
      }
    }
  }
}
